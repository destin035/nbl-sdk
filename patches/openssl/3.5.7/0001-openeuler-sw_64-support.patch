+  $CPUIDASM_sw_64=sw64cap.c sw_64cpuid.s
+
   $CPUIDASM_s390x=s390xcap.c s390xcpuid.S
 
   $CPUIDASM_armv4=armcap.c armv4cpuid.S
@@ -130,6 +132,7 @@ GENERATE[ia64cpuid.s]=ia64cpuid.S
